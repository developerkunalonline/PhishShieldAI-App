<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PhishShieldAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color - transparent for gradient effect. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_dark_start</item>
        <item name="android:windowBackground">@color/bg_dark_start</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Input styling -->
        <item name="colorControlNormal">@color/glass_stroke</item>
        <item name="colorControlActivated">@color/primary</item>
        <item name="colorAccent">@color/secondary</item>
    </style>

    <style name="Theme.PhishShieldAI.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Glassmorphic TextInputLayout style -->
    <style name="GlassTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_focused</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/accent_cyan</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
    </style>

    <!-- Glass Button style -->
    <style name="GlassButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Glass Card style -->
    <style name="GlassCard">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="cardBackgroundColor">@color/glass_bg</item>
    </style>
</resources>
